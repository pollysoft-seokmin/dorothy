# Database (Neon Postgres)
# Use the pooled connection string for serverless (host has "-pooler" suffix).
DATABASE_URL="postgresql://user:password@ep-xxxxx-pooler.region.aws.neon.tech/dorothy?sslmode=require"

# Better Auth
# Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=""
# Public URL of the deployment. Locally: http://localhost:3000
BETTER_AUTH_URL="http://localhost:3000"
# Comma-separated extra origins allowed by Better Auth (e.g. Vercel preview domains).
BETTER_AUTH_TRUSTED_ORIGINS=""

# Google OAuth (Cloud Console > Credentials > OAuth client ID)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
